#!/usr/bin/env bash
set -euo pipefail

# ANSI colors (modifiable)
RED="\033[31m" GREEN="\033[32m" YELLOW="\033[33m" BLUE="\033[34m" BOLD="\033[1m" RESET="\033[0m"

# Prefix for all output
PREFIX="gsynch: "

# Defaults (can be overridden by env and CLI)
BRANCH="main"
URL=""

ONLY_PATH=""
DRY_RUN=0
NO_COMMIT=0
DEBUG=0

OVERRIDE_STAGED=0
OVERRIDE_MODIFIED=0
OVERRIDE_UNTRACKED=0
OVERRIDE_ALL=0
ALLOW_FORCED_PUSH=0
NO_LOCAL_DELETE=0

prefix() { local prefix="$1" ; shift ; "$@" > >(sed 's/^/'$prefix' /') 2> >(sed 's/^/'${prefix}'ᵉ /' >&2)  ; }
#
# time unbuffer bash -ic 'ls -l'   > >(sed 's/^/[OUT] /')   2> >(sed 's/^/[ERR] /' >&2)

show_help()
{
echo -e "
${BOLD}gsynch - synchs current directory with a git repository${RESET}

Usage:
  gsynch [options]

Options:
  --branch <branch>           Branch name (default: main)
  --url <url>                 Remote URL
  --only <path>               Sync only a subdirectory
  --dry-run                   Show what would happen without modifying anything
  --no-commit                 Apply changes but do not commit

  --override-staged           Allow overwriting staged changes
  --override-modified         Allow overwriting modified tracked files
  --override-untracked        Allow overwriting untracked files
  --override-all              Allow overwriting all local changes (equivalent to all overrides)

  --no-local-delete           keep file even if was deleted in the git repo
  --allow-forced-push         Allow synchronization to continue even if a forced push is detected

  --debug                     Show debug information
  -h, --help                  Show this help message
"
}

# --- Load from environment ---------------------------------------------------

[ -n "${GSYNCH_URL:-}" ]    && URL="$GSYNCH_URL"
[ -n "${GSYNCH_BRANCH:-}" ] && BRANCH="$GSYNCH_BRANCH"

# --- Handle options ----------------------------------------------------------

while [ $# -gt 0 ]; do
    case "$1" in
        --branch)             BRANCH="$2";            shift 2 ;;
        --url)                URL="$2";               shift 2 ;;
        --only)               ONLY_PATH="$2";         shift 2 ;;
        --dry-run)            DRY_RUN=1;              shift ;;
        --no-commit)          NO_COMMIT=1;            shift ;;
        --debug)              DEBUG=1;                shift ;;
 
        --override-staged)    OVERRIDE_STAGED=1;      shift ;;
        --override-modified)  OVERRIDE_MODIFIED=1;    shift ;;
        --override-untracked) OVERRIDE_UNTRACKED=1;   shift ;;
        --override-all)       OVERRIDE_ALL=1;         shift ;;
        --no-local-delete)    NO_LOCAL_DELETE=1;      shift ;;

        --allow-forced-push)  ALLOW_FORCED_PUSH=1;    shift ;;

        -h|--help)            show_help;              exit 0 ;;

        *) echo -e "${RED}${PREFIX}Unknown argument:${RESET} $1"; exit 1 ;;
    esac
done

if [ $OVERRIDE_ALL -eq 1 ]; then
    OVERRIDE_STAGED=1
    OVERRIDE_MODIFIED=1
    OVERRIDE_UNTRACKED=1
fi

# --- Required variables ------------------------------------------------------

missing=0

if [ -z "$BRANCH" ]; then
    echo -e "${RED}${PREFIX}ERROR:${RESET} BRANCH is not set. Use --branch <branch> or GSYNCH_BRANCH."
    missing=1
fi

if [ -z "$URL" ]; then
    echo -e "${RED}${PREFIX}ERROR:${RESET} URL is not set. Use --url <url> or GSYNCH_URL."
    missing=1
fi

sanitize() { echo "$1" | sed 's/[^A-Za-z0-9_-]/_/g' ; }

REMOTE="$(sanitize "${URL#https://}")"

if [ $missing -eq 1 ]; then
    echo -e "${YELLOW}${PREFIX}Aborting due to missing required configuration.${RESET}"
    exit 1
fi

# --- Detect empty directory --------------------------------------------------

shopt -s nullglob dotglob
files=(*)
shopt -u nullglob dotglob

if [ ${#files[@]} -eq 0 ]; then
    echo -e "${BLUE}${PREFIX}Directory is empty. Cloning upstream...${RESET}"

    if [ $DRY_RUN -eq 0 ]; then
        git clone --branch "$BRANCH" "$URL" .
        git remote remove origin || true
    else
        echo -e "${PREFIX}[DRY RUN] Would run: git clone --branch $BRANCH $URL ."
        echo -e "${PREFIX}[DRY RUN] Would run: git remote remove origin"
    fi

    echo -e "${GREEN}${PREFIX}Initial clone complete.${RESET}"
    exit 0
fi

# --- Ensure working directory is a Git repo ----------------------------------

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo -e "${YELLOW}${PREFIX}Working directory is not a Git repo. Initializing...${RESET}"

    if [ $DRY_RUN -eq 0 ]; then
        git init &>/dev/null
        git add . &>/dev/null
        git commit -m "Initial import of existing working directory" &>/dev/null
    else
        echo -e "${PREFIX}[DRY RUN] Would run: git init"
        echo -e "${PREFIX}[DRY RUN] Would run: git add ."
        echo -e "${PREFIX}[DRY RUN] Would run: git commit -m 'Initial import of existing working directory'"
    fi
fi

# --- Remote setup ------------------------------------------------------------

if git remote get-url "$REMOTE" >/dev/null 2>&1; then
	# echo -e "${BLUE}${PREFIX}Updating remote URL ${BOLD}$REMOTE ($URL)${RESET}"
    [ $DRY_RUN -eq 0 ] && git remote set-url "$REMOTE" "$URL"
else
	# echo -e "${BLUE}${PREFIX}Adding remote ${BOLD}$REMOTE ($URL)${RESET} "
    [ $DRY_RUN -eq 0 ] && git remote add "$REMOTE" "$URL"
fi

# --- Fetch and detect forced push -------------------------------------------

REF="$REMOTE/$BRANCH"
OLD_SHA=$(git rev-parse --short=7 "$REF" 2>/dev/null || echo "")

if [ $DRY_RUN -eq 0 ]; then
    git fetch "$REMOTE" &>/dev/null
else
    git fetch "$REMOTE" --dry-run
fi

SHA_remote=$(git rev-parse --short=7 "$REF")

[ -n $OLD_SHA ] && commits_count=$(git rev-list --count $OLD_SHA.."$REF") || commits_count=0 
# [ $commits_count -le 1 ] && display_count='' || display_count="(commits: $commits_count)"
display_count="(commits: $commits_count)"

#
# --- Display header ----------------------------------------------------------

# subject="$(git rev-list --format='%B' --max-count=1 $REF | sed -n 2p)"
# relative_time="$(git rev-list --format='%ar' --max-count=1 $REF | sed -n 2p)"

echo -e "${BLUE}${PREFIX}Syncing ${BOLD}$URL:$BRANCH $display_count${RESET}"

git rev-list --format='(%h) %s (%ar)' --max-count=$commits_count "$REF" | \
    while IFS= read ignore ; read S ; do echo -e "${BLUE}${PREFIX}${BOLD}$S${RESET}" ; done

[ $DRY_RUN -eq 1 ] && echo -e "${YELLOW}${PREFIX}[DRY RUN ENABLED]${RESET}"

[ -n "$ONLY_PATH" ] && echo -e "${BLUE}${PREFIX}Syncing only subdirectory:${RESET} $ONLY_PATH"

# -----------------------------------------------------------------------------

[ $DEBUG -eq 1 ] &&
    {
    echo local:
    git log --oneline --graph --decorate

    echo remote:
    git log "$REF" --oneline --graph --decorate

    echo check with: git merge-base --is-ancestor "$OLD_SHA" "$SHA_remote"
    }

if [ -n "$OLD_SHA" ] && [ "$OLD_SHA" != "$SHA_remote" ]; then

    echo -e "${BLUE}${PREFIX}Checking for forced push...${RESET}"

    if git merge-base --is-ancestor "$OLD_SHA" "$SHA_remote"; then
        :
    else
        echo -e "${YELLOW}${PREFIX}Upstream branch is force-pushed; sync would override history.${RESET}"

        if [ $ALLOW_FORCED_PUSH -eq 0 ]; then
            echo -e "${RED}${PREFIX}Aborting due to forced push. Use --allow-forced-push to proceed.${RESET}"
            exit 1
        else
            echo -e "${YELLOW}${PREFIX}--allow-forced-push set. Continuing despite forced push.${RESET}"
        fi
    fi
fi

# --- Upstream commit message -------------------------------------------------

# UPSTREAM_MSG=$(git log -1 --pretty=%B "$REF")
UPSTREAM_MSG=$(git log -1 --pretty=%s "$REF")
UPSTREAM_SHA=$(git log -1 --pretty=%h "$REF")
COMMIT_MSG="Sync from $REF ($UPSTREAM_SHA): $UPSTREAM_MSG"

# --- Determine upstream file list -------------------------------------------

if [ -n "$ONLY_PATH" ]; then
    UPSTREAM_FILES=$(git diff --name-only "$REF" -- "$ONLY_PATH")
else
    # UPSTREAM_FILES=$(git ls-tree -r --name-only "$REF")
    UPSTREAM_FILES=$(git diff --name-only "$REF")
fi

# --- Local state classification ----------------------------------------------

STAGED_FILES=$(git diff --cached --name-only)
MODIFIED_FILES=$(git diff --name-only)
UNTRACKED_FILES=$(git ls-files --others --exclude-standard)

ANY_OVERRIDE=0
if [ $OVERRIDE_STAGED -eq 1 ] || [ $OVERRIDE_MODIFIED -eq 1 ] || [ $OVERRIDE_UNTRACKED -eq 1 ]; then
    ANY_OVERRIDE=1
fi

# --- Blocking semantics when no overrides -----------------------------------

if [ $ANY_OVERRIDE -eq 0 ]; then
    if [ -n "$STAGED_FILES" ] || [ -n "$MODIFIED_FILES" ]; then
        echo -e "${RED}${PREFIX}ERROR:${RESET} Working tree or index has uncommitted changes."
        git status --short
        echo -e "${RED}${PREFIX}Use --override-staged/--override-modified/--override-all to override.${RESET}"
        exit 1
    fi

    OVERWRITTEN=()
    if [ -n "$UNTRACKED_FILES" ]; then
        while IFS= read -r f; do
            if grep -Fxq "$f" <<< "$UPSTREAM_FILES"; then
                OVERWRITTEN+=("$f")
            fi
        done <<< "$UNTRACKED_FILES"
    fi

    if [ ${#OVERWRITTEN[@]} -gt 0 ]; then
        echo -e "${RED}${PREFIX}ERROR:${RESET} These untracked files would be overwritten:"
        printf ' - %s\n' "${OVERWRITTEN[@]}"
        echo -e "${PREFIX}Use --override-untracked or --override-all to override."
        exit 1
    fi
fi

# --- Determine changed files -------------------------------------------------

if git rev-parse HEAD >/dev/null 2>&1; then
    if [ -n "$ONLY_PATH" ]; then
        CHANGED=$(git diff --name-status "$REF" -- "$ONLY_PATH")
    else
        CHANGED=$(git diff --name-status "$REF")
    fi
else
    if [ -n "$ONLY_PATH" ]; then
        CHANGED=$(git diff --name-status "$REF" -- "$ONLY_PATH" || true)
    else
        CHANGED=$(git diff --name-status "$REF" || true)
    fi
fi

[ $DRY_RUN -eq 1 ] && {

    if [ -n "$CHANGED" ]; then
        echo -e "${BLUE}${PREFIX}Files that would be updated:${RESET}"
        echo "$CHANGED"
    fi

    echo -e "${YELLOW}${PREFIX}[DRY RUN] Not modifying working tree.${RESET}"
    exit 0
}

if [ -z "$CHANGED" ]; then
    echo -e "${GREEN}${PREFIX}Already up to date. No changes.${RESET}"
    exit 0
fi

# --- Selective apply of upstream tree ---------------------------------------

# echo -e "${BLUE}${PREFIX}Applying upstream tree with override semantics...${RESET}"

for f in $UPSTREAM_FILES; do
    is_staged=0
    is_modified=0
    is_tracked=0
    is_untracked=0

    if git ls-files --error-unmatch "$f" >/dev/null 2>&1; then
        is_tracked=1
        if git diff --cached --name-only -- "$f" | grep -q .; then
            is_staged=1
        fi
        if git diff --name-only -- "$f" | grep -q .; then
            is_modified=1
        fi
    else
        if [ -e "$f" ]; then
            is_untracked=1
        fi
    fi

    if git diff --name-status --diff-filter=A HEAD.."$REF" -- "$f" | grep -q . ; then
        upstream_state='added'
    elif git diff --name-status --diff-filter=D HEAD.."$REF" -- "$f" | grep -q . ; then
        upstream_state="${YELLOW}deleted${RESET}"
        if [ $NO_LOCAL_DELETE -eq 1 ] ; then
            echo -e "${BLUE}${PREFIX}Syncing ${BOLD}$f${RESET}${BLUE} "\
                    "(staged: $is_staged, modified: $is_modified, untracked: $is_untracked, upstream: $upstream_state${BLUE})${RESET}"\
                    "${YELLOW} [preserved]{RESET}"
            continue
        fi
    else
        upstream_state='modified'
    fi

    # if [ $ANY_OVERRIDE -eq 1 ]; then
        if [ $is_staged -eq 1 ] && [ $OVERRIDE_STAGED -eq 0 ]; then
            echo -e "${YELLOW}${PREFIX}Preserving staged file: $f (staged: $is_staged, modified: $is_modified, untracked: $is_untracked)${RESET}"
            continue
        fi
        if [ $is_modified -eq 1 ] && [ $OVERRIDE_MODIFIED -eq 0 ]; then
            echo -e "${YELLOW}${PREFIX}Preserving modified file: $f (staged: $is_staged, modified: $is_modified, untracked: $is_untracked)${RESET}"
            continue
        fi
        if [ $is_untracked -eq 1 ] && [ $OVERRIDE_UNTRACKED -eq 0 ]; then
            echo -e "${YELLOW}${PREFIX}Preserving untracked file: $f (staged: $is_staged, modified: $is_modified, untracked: $is_untracked)${RESET}"
            continue
        fi
    # fi

    echo -e "${BLUE}${PREFIX}Syncing ${BOLD}$f${RESET}${BLUE}"\
            " (staged: $is_staged, modified: $is_modified, untracked: $is_untracked, upstream: $upstream_state${BLUE})${RESET}"

    git restore --source "$REF" --worktree --staged -- "$f"
done

# --- Skip commit if nothing changed -----------------------------------------

if git diff --cached --quiet; then
    echo -e "${GREEN}${PREFIX}No changes after restore. Nothing to commit.${RESET}"
    exit 0
fi

# --- Commit (unless --no-commit) --------------------------------------------

if [ $NO_COMMIT -eq 1 ]; then
    echo -e "${YELLOW}${PREFIX}--no-commit enabled. Changes staged but not committed.${RESET}"
else
    git commit -m "$COMMIT_MSG" &>/dev/null
fi

# --- Mirror tags -------------------------------------------------------------

TAGS=$(git tag --points-at "$SHA_remote")

if [ -n "$TAGS" ]; then
    echo -e "${BLUE}${PREFIX}Mirroring tags:${RESET}"
    while IFS= read -r tag; do
        echo " - $tag"
        git tag -f "$tag" "$SHA_remote"
    done <<< "$TAGS"
    echo
else
    # echo -e "${BLUE}${PREFIX}No tags to mirror.${RESET}"
    :
fi

[ $DEBUG -eq 1 ] &&
    {
    echo local after synch:
    git log --oneline --graph --decorate 
    }

SHA_local=$(git rev-parse --short=7 HEAD)
echo -e "${GREEN}${PREFIX}Synced remote ($SHA_remote) in $SHA_local.${RESET}"

